Interativa
    function fatorial(n){
        let resultado = 1;
        for (let i = 1; i <= n; i++) {
            resultado *= i;
        }
        return resultado;
    }

    recursiva
    function recursiva(n) {
        if ( n == 0 || n == 1) {
            return 1;
        }
        return n * recursiva(n - 1);